# 管理员后台
ADMIN_PASSWORD=coco2026

# GitHub（admin 面板内容同步用）
GITHUB_OWNER=your-github-owner
GITHUB_REPO=your-github-repo
GITHUB_TOKEN=your-github-token

# Netlify 部署用
NETLIFY_TOKEN=your_netlify_token_here
NETLIFY_SITE_ID=your-netlify-site-id

# Supabase config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Embedding config（火山方舟 Doubao 多模态 Embedding API）
EMBEDDING_API_BASE=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_MODEL=doubao-embedding-vision-251215
EMBEDDING_DIMENSIONS=2048

# 生成/更新向量命令：
# npx tsx --env-file=.env.local scripts/generate-qa-embeddings.ts

# LLM config for AICOCO / teacher-ai（OpenAI 兼容格式）
# 选项 1：火山方舟
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=your-volcengine-model-id

# 选项 2：OpenAI ChatGPT
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 选项 3：DeepSeek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

LLM_API_KEY=your_llm_api_key_here
