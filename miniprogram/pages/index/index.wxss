.page {
  display: flex;
  flex-direction: column;
}

/* 通用卡片 */
.card {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 20rpx rgba(233, 138, 160, 0.08);
  border: 1rpx solid var(--pink-soft);
}
.card-accent {
  background: linear-gradient(135deg, var(--pink-soft), #ffffff);
  border: 1rpx solid var(--pink);
}

.mt-12 {
  margin-top: 24rpx;
}

/* 主按钮 / 次按钮 */
.btn-primary {
  display: inline-block;
  padding: 22rpx 56rpx;
  border-radius: 999rpx;
  background: var(--pink-deep);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(233, 138, 160, 0.25);
}
.btn-ghost {
  display: inline-block;
  padding: 22rpx 48rpx;
  border-radius: 999rpx;
  background: transparent;
  color: var(--pink-deep);
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid var(--pink);
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 96rpx 50rpx 80rpx;
  background: linear-gradient(to bottom, var(--pink-soft), var(--background));
}
.hero-logo {
  width: 320rpx;
  height: 320rpx;
}
.hero-subtitle {
  margin-top: 36rpx;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  color: var(--pink-deep);
}
.hero-text {
  margin-top: 36rpx;
  max-width: 560rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(74, 59, 64, 0.75);
}
.hero .btn-primary {
  margin-top: 56rpx;
}

/* 区块 */
.section {
  padding: 80rpx 40rpx;
}
.section-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.title-en {
  font-size: 56rpx;
  text-transform: uppercase;
  color: var(--pink-deep);
}
.title-zh {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--foreground);
}
.title-line {
  margin-top: 24rpx;
  width: 96rpx;
  height: 2rpx;
  background: var(--pink);
}

/* 品牌介绍 */
.brand-intro {
  margin: 56rpx auto 0;
  max-width: 620rpx;
  text-align: center;
  line-height: 1.8;
  font-size: 28rpx;
  color: rgba(74, 59, 64, 0.8);
}
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-top: 56rpx;
}
.feature-card {
  flex: 1 1 100%;
  padding: 44rpx;
  text-align: center;
}
.feature-t {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--pink-deep);
}
.feature-d {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(74, 59, 64, 0.7);
}

/* 诊断老师 */
.teacher-photo-wrap {
  margin: 56rpx auto 0;
  width: 520rpx;
  height: 650rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(233, 138, 160, 0.12);
  border: 1rpx solid var(--pink-soft);
}
.teacher-photo {
  width: 100%;
  height: 100%;
}
.teacher-name {
  margin-top: 40rpx;
  text-align: center;
  font-size: 44rpx;
  color: var(--pink-deep);
}
.teacher-role {
  margin-top: 8rpx;
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: rgba(74, 59, 64, 0.6);
}
.teacher-bio {
  margin-top: 24rpx;
  line-height: 1.8;
  font-size: 28rpx;
  color: rgba(74, 59, 64, 0.8);
}

/* 诊断项目 */
.service-list {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.service-card {
  padding: 48rpx;
}
.service-en {
  font-size: 36rpx;
  color: var(--pink-deep);
}
.service-zh {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
}
.service-desc {
  margin-top: 20rpx;
  font-size: 27rpx;
  color: rgba(74, 59, 64, 0.7);
}
.service-price {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--pink-deep);
}

/* 诊断明细 */
.detail-list {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.detail-card {
  padding: 40rpx;
}
.detail-en {
  font-size: 32rpx;
  color: var(--pink-deep);
}
.detail-zh {
  font-size: 30rpx;
  font-weight: 600;
}
.detail-items {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.detail-item {
  display: flex;
  gap: 16rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: rgba(74, 59, 64, 0.8);
}
.detail-num {
  flex-shrink: 0;
  font-weight: 600;
  color: var(--pink-deep);
}

/* 预约流程 */
.process-card {
  flex: 1 1 100%;
  padding: 44rpx;
  text-align: center;
}
.process-step {
  font-size: 56rpx;
  color: var(--pink);
}
.process-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.process-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(74, 59, 64, 0.7);
}

/* 门店地址 */
.contact-card {
  margin-top: 56rpx;
  padding: 56rpx 44rpx;
  text-align: center;
}
.contact-address {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.6;
}
.contact-hours {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(74, 59, 64, 0.7);
}
.contact-btns {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

/* 页脚 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
  padding: 72rpx 40rpx;
  margin-top: 40rpx;
  background: rgba(253, 230, 236, 0.4);
  border-top: 1rpx solid var(--pink-soft);
}
.footer-logo {
  width: 88rpx;
  height: 88rpx;
}
.footer-title {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.footer-note {
  font-size: 25rpx;
  color: rgba(74, 59, 64, 0.6);
}
.footer-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(74, 59, 64, 0.4);
}
